

<div class="header-wrapper">
  {% if section.settings.topheader_actived == true  or settings.topheader2_actived == true %}
  <div class="topheader topheader-show-true {{ section.settings.topheader-spacing }}">
    <div class="topheader__wrapper" style="max-width:{{ section.settings.topheader_max_width }}; display:flex; align-items:center; {% if linklists[section.settings.quick_access].links != blank or section.settings.top_header_socials == true %}flex: 1;{% endif %}">
    {% endif %}
    {% if section.settings.topheader_flash_infos %}
      {% render 'flash-infos', html: section.settings.topheader_html, autoPlaySpeed: section.settings.topheader_flash_infos_autoplayspeed  %}
    {% else %}
      {% if section.settings.topheader_actived == true and settings.topheader2_actived == false %}
        {{ section.settings.topheader }}
      {% endif %}
    {% endif %}
    {% if settings.topheader2_actived == true %}
    {% assign livraison_offerte_a_partir_de = settings.free_shipping_price %}
    {% assign montant_avant_livraison_offerte = livraison_offerte_a_partir_de | times: 100.0 | minus: cart.total_price %} 
    {% if montant_avant_livraison_offerte > 0 %}	    
    {% if cart.total_price == 0 %}
    <p>{{ settings.free_shipping_text0 }} <strong class="free-shipping-bar-number">{{ montant_avant_livraison_offerte | money }}</strong> {{ settings.free_shipping_text0bis }}</p>
    {% else %}
    <p>{{ settings.free_shipping_text1 }} <strong class="free-shipping-bar-number">{{ montant_avant_livraison_offerte | money }}</strong> {{ settings.free_shipping_text2 }}</p>
    {% endif %}
    {% else %}
    <span class="free-shipping-bar-on">{{ settings.free_shipping_text3 }}</span>
    {% endif %}
    {% endif %}    
    {% if linklists[section.settings.quick_access].links != blank or section.settings.top_header_socials %}
    <ul class="quick-access">
      {% for link in linklists[section.settings.quick_access].links %}
      <li><a href="{{ link.url }}">{{ link.title }}</a></li>
      {% endfor %}
      {% if section.settings.top_header_socials %}
      {% render 'social-icons' %}
      {% endif %}
    </ul>
    {% endif %}
    {% if section.settings.topheader_actived == true  or settings.topheader2_actived == true %}
    </div>
  </div>
  {% endif %}
  <header class="site-header cont-header  {{ section.settings.header-spacing }}" role="banner" data-section-id="{{ section.id }}" data-section-type="header-section"  >
	
    <div class="header-grid header-grid__logo hide-mobile">
      {% if template.name == 'index' %}
      <div class="header-logo" itemscope itemtype="http://schema.org/Organization">
        {% else %}
        <div class="h1 header-logo" itemscope itemtype="http://schema.org/Organization">
          {% endif %}
          {% if section.settings.logo %}
          {% capture image_size %}{{ section.settings.logo_max_width | escape }}x{% endcapture %}
          <a class="logo-link" href="{{ routes.root_url }}">
            <img src="{{ section.settings.logo | img_url: image_size }}"
              loading="lazy"
              srcset="{{ section.settings.logo | img_url: image_size }} 1x, {{ section.settings.logo | img_url: image_size, scale: 2 }} 2x"
              width= "{{ section.settings.logo.width }}"
              height= "{{ section.settings.logo.height }}" 
              style="max-width:{{ section.settings.logo_max_width | escape }}px"
              class="logo-header"        
                {% if section.settings.header_transparent %}class="logo-header-no-transparent"{% endif %}                                                
                alt="{{ shop.name }}"
              >
            
            {% if section.settings.header_transparent and template == "index" %}
            {% if section.settings.logo2 %}
            {% capture image_size %}{{ section.settings.logo2_max_width | escape }}x{% endcapture %}
            <img src="{{ section.settings.logo2 | img_url: image_size }}"
                 srcset="{{ section.settings.logo2 | img_url: image_size }} 1x, {{ section.settings.logo2 | img_url: image_size, scale: 2 }} 2x"
                 class="logo-header-transparent"
                 loading="lazy"            
                 width= "{{ section.settings.logo2.width }}"
                 height= "{{ section.settings.logo2.height }}"                   
                 alt="{{ shop.name }}"
                 >
            {% endif %}
            {% endif %}
          </a>
          
          {% else %}
          <a href="/">{{ shop.name }}</a>
          {% endif %}
          {% if template.name == 'index' %}
          </div>
        {% else %}
        </div>
      {% endif %}
    </div>
    <div class="header-grid header-grid__nav">
      <div class="grid-item text-center large--text-right">
        <nav class="nav-bar" role="navigation">
          <div {% if section.settings.type_headers != 'header3' %} style="padding:0 1.6rem" {% endif %}>
            {% render 'site-nav', section: section %} 
          </div>
        </nav>
      </div> 
    </div>

    <div class="header-grid header-grid__links  hide-mobile"> 
      {% unless section.settings.search_actived %}        
      <a href="#" onclick="openSearch()" aria-label="Search" class="header-cart-btn header-action-search mobileNavBar-link openBtn">
        <i class="fa fa-search" aria-hidden="true"></i>
        <span class="elem-hidden">Search</span>
      </a>
      {% endunless %} 

      {% if shop.customer_accounts_enabled %}
      <a href="/account" aria-label="Account" class="header-cart-btn header-action-account boxconnexion-show-{{ section.settings.header_box_actived }}">
       {{ section.settings.header_icon_user }}
        <span class="elem-hidden">{% if customer %}
        {{ 'customer.account.title' | t }} 
        {% else %}
        {{ 'customer.login.title' | t }} 
        {% endif %}
        </span>
      </a>
      {% endif %} 

      <a href="{{ routes.cart_url }}" aria-label="Cart" class="header-cart-btn header-action-cart {% if settings.ajax_cart_method != 'page' %} cart-toggle {% endif %}">
       {{ section.settings.header_icon_cart }}
        <span class="cart-count cart-badge--desktop {% if cart.item_count == 0 %}hidden-count{% endif %}">{{ cart.item_count }}</span>
        <span class="elem-hidden">Cart</span>
      </a>

    </div>

  </header>

  {% render 'mobile-navbar', section: section %}

</div>