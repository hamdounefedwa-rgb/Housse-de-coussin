

/* #V1 */
{% if settings.theme_version == "2" %}

.mono-produit-true .addToCartForm {
  margin-left:auto;
  margin-right:auto;
}

.cont-qty-mono {
  margin:0 auto;
  display:block;
}

.two-quarters, .four-fifths, .large--four-fifths { width:100%; }

.section-header { display:block !important; text-align:center; }

.cont-featured-box { min-width:100% }

.boxconnexion-show-true { display:none; }

.grid-uniform { justify-content:center; }

.product-meta { display:block; }

form * {
  margin-left: auto !important; 
  margin-right: auto !important; 
}

.inline-list li { display:inline-block; }
.addToCart { margin:0 auto; } 

.mono-produit-true .breadcrumb {
  display:none; 
}
.mono-produit-true .is-template-index {
  padding-top: 25px;
}
@media screen and (max-width: 749px) {
  .mono-produit-true .is-template-index {
    padding-top: 15px;
  }
}
.mono-produit-true .text-reason {
  margin-top: 10px;
  margin-bottom: 5px;
}
.mono-produit-true .badges {
  margin: 0 auto;
}
.mono-produit-true .badges img {
  margin-top: 15px;
  margin-bottom: 10px;
}
.mono-produit-true .sidebar {
  display: none;
}


.mono-produit-true .grid-content {
  display:block;
  text-align:center;
  padding-top:25px;
}

.mono-produit-true .grid-content h1 {
  margin:0;
}

.mono-produit-true .swatch .swatch-inner {
  display:block; 
}

.mono-produit-true .inline-list li {
  justify-content:center;
}

.mono-produit-true .cont-add-btns { margin:0 auto; }
.mono-produit-true .col50 .cont-shake {
  display:block;
}

.mono-produit-true hr.hr--clear {
  margin:5px 0; 
}
.mono-produit-true .product-item--price .h1 {
  font-size:1.5em; 
}

.mono-produit-true #productPrice-product-template small {
  font-size:100%; 
}

.mono-produit-true .rte ul {
  margin-left:0; 
}
.mono-produit-true .special-offer-v1, 
.mono-produit-true .add-to-cart-bundle { margin:0 auto; }

.mono-produit-true video {
  max-width:100%; 
}
.mono-produit-true .rte h2 {
  text-transform:initial;
  font-size:1.9em;
  margin-bottom:30px;
  font-weight:bold;
}

.mono-produit-true .rte h2
.mono-produit-true .rte h3 { 
  margin-top:20px;
  margin-bottom:20px; 
}
.mono-produit-true .rte h4 {  
  margin-bottom:25px; 
}

.mono-produit-true {
  text-align:center;
}
.mono-produit-true .large--one-half, .mono-produit-true .large--two-quarters, .mono-produit-true .large--three-sixths, 
.mono-produit-true .large--four-eighths, .mono-produit-true .large--five-tenths, .template-product .mono-produit-true .large--six-twelfths {
  width:100%;
  margin-bottom:25px;
  float:none ;
  display:block;
}

.mono-produit-true .header1 .grid--full>.grid-item {
  margin-bottom:15px;
}

.mono-produit-true .spr-form>form {
  text-align:left; 
}

.mono-produit-true .site-nav {
  text-align: left;
  display: inline-block;  
  width: auto;
  margin: 0 auto;
}

.template-index .mono-produit-true .collection-list-section .grid-item {
  padding:5px; 
}
.template-list-collections .mono-produit-true .main-content .grid-item {
  padding-left:30px; 
}
@media screen and (max-width: 749px) {
  .section-header--left {
    text-align:center ; 
  }
  .mono-produit-true .site-nav {
    display:block;
    margin:15px 17px;
  }
  .template-list-collections .mono-produit-true .grid-item {
    padding-left:0; 
  }
}

.mono-produit-true .product-photo-thumbs .grid-item {
  padding:1px 1px 0 0;
}

.cont-title-mono {
  display:none; 
}
.cont-title-all {
  display:block; 
  overflow:hidden; 
}
hr.after-title { display:none; background-color: var(--colorTextBody ); margin:15px 0 5px 0; }
.mono-produit-true .cont-title-mono {
  display:block; 
  margin-bottom:25px;
}
.mono-produit-true .cont-title-mono h1 {
  margin-bottom:0 ; 
}
.mono-produit-true .cont-title-all {
  display:none; 
}

.mono-produit-true .large--two-fifths, .mono-produit-true .large--four-tenths, 
.mono-produit-true .large--three-fifths, .mono-produit-true .large--six-tenths {
  width:100%;
  max-width:850px;
  margin:0 auto;
  margin-bottom:0;
  float:none ;
  display:block;
}
/*.mono-produit-true footer .large--two-fifths, .mono-produit-true footer .large--four-tenths, 
.mono-produit-true footer .large--three-fifths, .mono-produit-true footer .large--six-tenths {
  width:50%;
  max-width:100%;
  margin:0 auto;
  margin-bottom:0;
  float:left ;
  display:block;
}*/
.mono-produit-true .large--eleven-twelfths {
  width:100%; 
}
.mono-produit-true .quantity, .mono-produit-true .quantity2, .mono-produit-true .quantity-selector {
  margin:0 auto 12px auto ; 
  float:none ;
  display:block ;
  clear:both; 
}

.mono-produit-true .liv_carac li {
  background:none;
  padding-left:0;
}
.mono-produit-true footer .large--two-fifths {
  max-width:var(--page-width);
}

.mono-produit-true .my-tab {
  width:100%;
  max-width:750px;
  margin:0 auto;
  margin-bottom:0;
  float:none ;
  display:block;
}
.mono-produit-true #my-tab {
  border:none; 
  margin:0 auto;
}
.mono-produit-true #gdcdtimer {
  margin:15px auto;
}
.mono-produit-true .tabs {
  display:none; 
}
.mono-produit-true #tab-1, .mono-produit-true #tab-2, .mono-produit-true #tab-3, .mono-produit-true #tab-4 {
  border:none;
  padding:0;
}

.mono-produit-true.mono-produit-true footer,
.template-collection .mono-produit-true .main-content h1 {
  text-align:left; 
}
.mono-produit-true .main-content h1.title-primary {
  font-size:31px; 
  font-weight:bold; 
}

.template-collection .mono-produit-true .main-content .product-item--price .h1, 
.template-product .mono-produit-true .main-content h1, 
.template-collection .mono-produit-true .main-content h1 {
  text-align:center ; 
}
.template-collection .mono-produit-true .sortbyheader {
  display:none; 
}
.mono-produit-true .product-description {
  margin-top:15px;
  padding:0 ; 
}

@media screen and (max-width: 1023px) {
  .mobileNavBar-link {
    text-align:left; 
  }
}
@media screen and (max-width: 749px) {
  .template-collection .mono-produit-true .main-content h1 {
    text-align:center ; 
  }

  .mono-produit-true .main-content h1.title-primary {
    font-size:24px; 
  }  
}

{% endif %}

/* #V2 */

{% if settings.theme_version == "3" %}
.section-header { text-align:center; }
.section-header.section-header--layout-0 .h1 { margin-left:auto; }
@media screen and (min-width: 750px) {
  .layout-0 .featured-link--image, .layout-66 .featured-link--image, .layout-0 .featured-link--half, .layout-66 .featured-link--half {
    width: calc(50% - 0px);
  }
}

.mono-product-v2 .featured-link--half .text-align--left, .mono-product-v2 .featured-link--half .text-align--right {
  text-align:center; 
}
.mono-product-v2 .featured-link--section {
  margin-bottom:0;
}
.mono-product-v2 .featured-link--section .collection-title:after {
  display:block;
  content:"";
  width:10%;

    height:3px;
    margin:10px auto;
}
.mono-product-v2 .collection-list-section, .mono-product-v2 .collection-list-section .grid-uniform {
  max-width:100%;   
}

.mono-product-v2 .product-photo-thumbs-v2 li {

  margin:1% 1% 1% 1% ;
  float:left;
  padding:0;
  height:215px ;
  border:1px solid rgba(000,000,000,0.3);
}

.mono-product-v2 .featured-product {
  margin-top:0; 
}

.mono-product-v2.template-cart .main-content span.h2 { text-align:right; }

.mono-product-v2 .social-sharing, .mono-product-v2 .social-sharing a { margin-bottom:0; }

.mono-product-v2 .cont-photos { padding-bottom:15px ; }

/* RWD */
@media screen and (min-width: 1024px) {
  .mono-product-v2 .featured-link-text {
    padding:35px 60px;  
  }
}  
@media screen and (max-width: 749px) { 
  .mono-product-v2 .sticky-atc {
    margin:0;
    padding:7px 2px;
  }

  .mono-product-v2 .product-photo-thumbs-mono li {   
    min-height:110px;
    border:none;
  }

  .mono-product-v2 .featured-product .large--three-fifths {    
    padding:5px 15px;
  }
  .mono-produit-true .col50 { margin-bottom:15px; }
}
.mono-produit-true .cont-selector .selector-wrapper { width:46%; padding:0 1%; }

{% endif %}