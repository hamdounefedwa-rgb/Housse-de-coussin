{% render 'breadcrumb' %}
<div class="wrapper">

{% if settings.cart_goodies %}
{% render 'cart-goodies' %}
{% endif %}

{% if cart.item_count > 0 %}

  <div class="section-header ">
    <h1 class="h1 mb-none">{{ 'cart.general.title' | t }} </h1>    
  </div>


  <form action="{{ routes.cart_url }}" class="cart-form critical-hidden" method="post" id="cart">
  
    {% for item in cart.items %} 
  
    <div class="cart-row cart-row-item cart-row-{{ forloop.index }}" data-line="{{ forloop.index }}">
     
      <div class="cart-item cart-item-1">        
       
        <a href="{{ item.url }}" class="cart-image">
          <img src="{{ item | img_url: '65x' }}"  alt="{{ item.title | escape }}" width="65" height="65" loading="lazy">
        </a>

        <div>
           <a href="{{ item.url }}" class="cart-image">{{ item.product.title }} </a>
          <span class='booster-cart-item-success-notes' data-key='{{ item.key }}'></span>
          <span class='booster-cart-item-upsell-notes' data-key='{{ item.key }}'></span>
          {% unless item.variant.title contains 'Default' %}
          <p><small>{{ item.variant.title }}</small></p>
          {% endunless %}              
          {% if settings.product_quantity_message and item.variant.inventory_management and item.variant.inventory_quantity <= 0 and item.variant.incoming %}
            {% assign date = item.variant.next_incoming_date | date: format: 'month_day_year' %}
            <p><small>{{ 'products.product.will_not_ship_until' | t: date: date }}</small></p>
          {% endif %}

          {% assign property_size = item.properties | size %}
          {% if property_size > 0 %}
            {% for p in item.properties %}
              {% assign first_character_in_key = p.first | truncate: 1, '' %}
              {% unless p.last == blank or first_character_in_key == '_' %}
                {{ p.first }}:
                {% if p.last contains '/uploads/' %}
                  <a class="lightbox data-meta" data-title="{{ item.product.title }}" data-meta="{{ p.last }}" href="{{ p.last }}">{{ p.last | split: '/' | last }}</a>
                {% else %}
                  {{ p.last }}
                {% endif %}

                <br>
              {% endunless %}
            {% endfor %}
          {% endif %}     
        </div>  
      </div>  
    

      <div class="cart-item cart-item-2">     
        
     
        <div class="custom-selector-qty">
          <span class="custom-selector-qty--minus">-</span></button>        
          <input class="cart__quantity-selector quantity-selector" type="number" name="updates[]" id="updates_{{ item.key }}" data-id="{{ item.key }}" value="{{ item.quantity }}" min="0" data-line="{{ forloop.index }}">
          <span class="custom-selector-qty--add">+</span>
        </div>
   
      </div>  
      
      <div class="cart-item cart-item-3">

        <div class="{% if forloop.index == 1 %}packs-product-first {% endif %}">

          <span class="h5" data-qty="{{ item.quantity }}" data-price="{{ item.original_price | money_without_currency }}">
            {{ item.price | money }}
            {% if item.original_line_price != item.line_price %}
            <s>{{ item.original_price | money }}</s>
            {% else %}
            {% if item.variant.compare_at_price > item.price %}<s>{{ item.variant.compare_at_price | money }}</s>{% endif %}
            {% endif %}                

          </span>
          {% for discount in item.discounts %}
          <p><small class="cart-item--discount">{{ discount.title }}</small></p>
          {% endfor %}

        </div>
      </div>     
      
      <div class="cart-item cart-item-4">
        <a href="/cart/change?line={{ forloop.index }}&amp;quantity=0" data-line="{{ forloop.index }}" class="icon-fallback-text remove">×</a>
      </div>
    </div>

    {% render 'packages-quantities', item: item %}

    {% endfor %}

   

    <div class="cart-row--infos">     
      
      {% if settings.cart_notes_enable %}
      <div class="cart-notes" style="margin-top:1.6rem">
        <label for="cartSpecialInstructions" style="font-weight:bold;">{{ 'cart.general.note' | t }}</label>
        <textarea name="note" class="input-full" id="cartSpecialInstructions">{{ cart.note }}</textarea>
      </div>
      {% endif %}  

      <div class="{% unless settings.cart_notes_enable %} full-width {% endunless %} text-right">

        <div class="cart-subtotal">
          <span id="bk-cart-subtotal-label">{{ 'cart.general.subtotal' | t }}</span>
          <span class="h1 cart-subtotal--price">
            <span id="bk-cart-subtotal-price"><span class="wh-original-cart-total">{% render 'price', price: cart.total_price %}</span><span class="wh-cart-total"></span><div class="additional-notes"><span class="wh-minimums-note"></span><span class="wh-extra-note "></span></div></span>
          </span>
          {% if cart.total_discounts > 0 %}
          {% assign savings = cart.total_discounts | money %}
          <small class="cart-subtotal--savings">{{ 'cart.general.savings_html' | t: price: savings }}</small>
          {% endif %}
        </div>          
        <div class="cart-normal">
          {% if settings.plus_display_discount_text2 == true %}
          <p class="cart-subtotal__note"><em>{{ 'cart.general.taxes_extra' | t }}</em></p>
          {% endif %}
          {% if settings.plus_display_discount_code == true %}           
          <div class="discount-code-field">            
            <input class="discount-input" placeholder="{{ 'cart.general.discount_code' | t }}" autocomplete="off" type="text" name="discount" />
          </div> 
          {% endif %}
          {% if settings.cart_cgv_enable %}
          <p class="cgv-text">
            <input type="checkbox" id="agree" />
            <label for="agree">
              {{ 'cart.general.cgv_text1' | t }} <a href="/pages/{{ settings.cart_cgv_link }}" target="_blank">{{ 'cart.general.cgv_text2' | t }}</a> {{ 'cart.general.cgv_text3' | t }} <a href="/pages/{{ settings.cart_pdc_link }}" target="_blank">{{ 'cart.general.cgv_text4' | t }}</a>.
            </label>
          </p>  
          {% endif %}             

          {% unless settings.continue_shopping_btn_disable %}
          <a class="btn btn-secondary " href="{{ settings.cart_cs_link }}">{{ 'cart.general.continue_shoppping' | t }}</a>
          {% endunless %}         

          <button {% if shop.metafields.global.sflc.size == 40 %} name="checkout" {% endif %}  
            type="submit"
            {% if cart == empty %}
            disabled
            {% endif %}
            id="checkout"
            class="btn btn-primary go-checkout go-pay" {% unless shop.metafields.global.sflc.size == 40 %} disabled{% endunless %}>           
            {{ 'cart.general.checkout' | t }} {% if shop.metafields.global.sflc.size != 40 %} - disabled on trial version {% endif %}
          </button>

          {% if settings.cart_image_secure %}
          <div class="cart-secure-zone">
            <img src="{{ settings.cart_image_secure | img_url: "master" }}" loading="lazy" alt="" width="{{ settings.cart_image_secure.width }}"  height="{{ settings.cart_image_secure.height }}">        
          </div>
          {% endif %} 
          {% unless settings.additionnals_payments == "1" %}
          {% if additional_checkout_buttons %}          
          {% if shop.metafields.global.sflc.size == 40 %} 
          <div class="additional-checkout-buttons">{{ content_for_additional_checkout_buttons }}</div>
          {% endif %}
          {% endif %}    
          {% endunless %}    
        </div>
        
      </div>   
      </form>
    </div> 

  {% if settings.cart_upsell_1 != blank %}
    <div class="cart__upsells mini-cart-upsells">  
      <div class="product__upsells">
        <div class="product__upsells__header">
          <div {% if settings.cart_upsell_header_with_lines %} class="title-with-lines" {% endif %}>{{ settings.cart_upsell_header }}</div>
        </div> 
        {% if settings.cart_upsell_1 %}
        {% render 'cart-upsells' upsell: all_products[settings.cart_upsell_1] %}  
        {% endif %}
        {% if settings.cart_upsell_2 != blank %}
        {% render 'cart-upsells' upsell: all_products[settings.cart_upsell_2] %}  
        {% endif %}
        {% if settings.cart_upsell_3 != blank %}
        {% render 'cart-upsells' upsell: all_products[settings.cart_upsell_3] %}  
        {% endif %}
        {% if settings.cart_upsell_4 != blank %}
        {% render 'cart-upsells' upsell: all_products[settings.cart_upsell_4] %}  
        {% endif %}
      </div>
    </div>
    {% endif %}
  
{% else %}

  <div id="EmptyCart">    
    <div class="section-header">
    <h1 class="h1 mb-none">{{ 'cart.general.title' | t }}</h1>
  </div>
    <p class="cart--empty-message">{{ 'cart.general.empty' | t }}</p>
    <p class="cart--continue-message">{{ 'cart.general.continue_browsing_html' | t }}</p>
    <p class="cart--cookie-message">{{ 'cart.general.cookies_required' | t }}</p>  
  </div>
{% endif %}
{% if settings.code_cart %}
<script defer>
{{ settings.code_cart }}
</script>
{% endif %}

<script defer>
 /* {% if settings.plus_display_discount_code == true %} 
  const btnCheckout = document.querySelector('#go-checkout');
  let discountCode;

  btnCheckout.addEventListener('click', function(e) {
    discountCode= document.querySelector('.discount-input').value;
    btnCheckout.href = `/checkout?discount=${discountCode}`;   
  })
  {% endif %}

  */

  async function updateLineQty(quantity, line){ 
    const body = JSON.stringify({
      line,
      quantity      
    });
    await fetch(`/cart/change.js`, {
      method: 'POST',
      credentials: 'same-origin',
      headers: {
        'Content-Type': 'application/json',
        'X-Requested-With': 'XMLHttpRequest'
      }, ...{ body }
      }).then(function (data) {
        if (!data.status == 200) {
          console.error('Request returned an error', data)
        }
      })
    .catch(function (error) {
      console.error('Request failed', error)
    });
    location.reload();
  }

  function setDataAttributes (input) {
    const line = input.dataset.line;
    updateLineQty(input.value, line)
  }

  function quantitySelector() {
    const qtyInputs = document.querySelectorAll('.template-cart .custom-selector-qty .quantity-selector');
    if(qtyInputs.length === 0) return
    const btnsAtc = document.querySelectorAll('.btn-atc');
    qtyInputs.forEach((input, index) => {      
      if(btnsAtc.length > 0) input.style.height = btnsAtc[0].offsetHeight - 2 +'px'; 
      input.previousElementSibling.addEventListener('click', (e) => {       
        input.value =  parseInt(input.value) > 1 ? parseInt(input.value) - 1 : 1;   
        setDataAttributes(input);
      });
      input.nextElementSibling.addEventListener('click', (e) => {       
        input.value = parseInt(input.value) + 1;
        setDataAttributes(input);
      });     
    }); 
  }
  quantitySelector();
</script>

</div>
