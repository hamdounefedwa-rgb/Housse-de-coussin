{% assign grid_results = true %}
{% assign respond_js_secret_key = shop.domain | md5 %}
{% unless search.terms == respond_js_secret_key %}

  <div class="wrapper">
  <br />

  {% if search.performed %}

    {% paginate search.results by 20 %}

      {% if search.results_count == 0 %}
        <div class="section-header section-header--center">
          <h1 class="h2">{{ 'general.search.no_results_html' | t: terms: search.terms }}</h1>
        </div>
        {% render 'search-bar' %}

      {% else %}
        <div class="section-header section-header--center">
          <h1 class="h2">{{ 'general.search.results_for_html' | t: terms: search.terms }}</h1>
        </div>
        {% render 'search-bar' %}
        <hr class="hr--clear">

        {% if grid_results == false %}

          {% for item in search.results %}
            {% render 'search-result' %}
          {% endfor %}

        {% else %}

          <div class="grid-uniform flex-align-baseline flex-grow-none">
            {% for item in search.results %}
              {% assign grid_item_width = 'large--one-fifth medium--one-third small--one-half' %}
              {% render 'search-result-grid', grid_item_width: grid_item_width, item: item %}
            {% endfor %}
          </div>

        {% endif %}

      {% endif %}

      {% if paginate.pages > 1 %}
        <div class="text-center">
          {% render 'pagination-custom', paginate: paginate %}
        </div>
      {% endif %}

    {% endpaginate %}

  {% else %} 
    <h1 class="text-center h2">{{ 'general.search.title' | t }}</h1>
    {% render 'search-bar' %}
  {% endif %}
  
{% else %}
  {% render 'respond' %}
  {% layout none %}
{% endunless %}

</div>

{% schema %}
{  
  "name": {
    "fr": "Recherche",
    "es": "Buscar",
    "en": "Search"
  },
  "settings":[
    {
      "type": "checkbox",
      "id": "product_show_compare_at_price",     
      "label": {
        "fr": "Afficher le prix barré",
        "es": "Mostrar el precio tachado",
        "en": "Display the compare at price"
      },
      "default": false
    },
    {
      "type": "checkbox",
      "id": "product_show_saved_amount",      
      "label": {
        "fr": "Afficher l'économie",
        "es": "Mostrar el importe ahorrado",
        "en": "Display the savings amount"
      },
      "default": true
    }  
  ]
}
{% endschema %}