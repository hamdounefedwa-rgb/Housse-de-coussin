            {
              "value": "large--one-quarter",
              "label": "25%"
            },
            {
              "value": "large--one-third",
              "label": "33%"
            },
            {
              "value": "large--two-fifths",
              "label": "40%"
            },
            {
              "value": "large--two-quarters",
              "label": "50%"
            },
            {
              "value": " large--three-fifths",
              "label": "60%"
            },
            {
              "value": "large--two-thirds",
              "label": "67%"
