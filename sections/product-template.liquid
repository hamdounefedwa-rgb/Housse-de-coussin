

{% if settings.special_offer_v1 %} 
<link rel="stylesheet" href="{{ 'app-bundle-qty.css' | asset_url }}" media="all" >
{% endif %}

{% if settings.size_chart or product.metafields.se_product_z16.contenu_simple_html != blank or product.metafields.se_product_z16.identifiant_page != blank %}
<link rel="stylesheet" href="{{ 'app-size-chart.css' | asset_url }}" media="all" >
{% endif %}

<div id="section-id-{{ section.id }}"
     data-page-count="0"
     class="section-id-{{ section.id }} product-{{ product.id }} section-product-single {% unless section.settings.full_page %}wrapper {% endunless %}" 
     data-section-id="{{ section.id }}" 
     data-section-type="product-template"
     data-zoom-toggle="zoom-in"     
     data-related-enabled="{{ section.settings.product_related_enable }}"    
     data-title-height="{{ section.settings.grid_crop_title }}" 
     data-title-height-sm="{{ section.settings.grid_crop_title_sm }}" 
     data-title-truncate="{{ section.settings.title_truncate }}" 
     data-title-truncate-sm="{{ section.settings.title_truncate_sm }}"
     >

  {% if section.settings.breadcrumb_enable %}
  {% render 'breadcrumb' %} 
  {% endif %}
  
  <div class="wrapper1">       

    <div class="grid-content"> 

      {%- for block in section.blocks -%}

        {%- case block.type -%} 

        {%- when 'grid_open' -%}         
        
        <div class="grid-item {{ block.settings.grid_width_sm }} {{ block.settings.grid_width }}  grid-id-{{ block.id }} " id="{{ block.settings.id }}" {{ block.shopify_attributes }}>

        {%- when 'images' -%}         
        <div style="margin:0 auto;flex:1 0 100%;" {{ block.shopify_attributes }}>
          {% render "product-images", block: block, section: section, product: product %}
        </div>
          
        {%- when 'title' -%}  
        <div class="block-title block-{{ block.id }} {{ block.settings.class }}" id="{{ block.settings.id }} {{ block.shopify_attributes }}" {{ block.shopify_attributes }}>
          <h1 class="h1 title-primary">{{ product.title }}</h1>        
          <div class="divider">{{ block.settings.block_title_divider }}</div>
          {% if product.metafields.se_product_z4.contenu_simple_html != blank or product.metafields.se_product_z4.identifiant_page != blank %}
          <div class="se-meta se-meta-z4">
            {% if product.metafields.se_product_z4.contenu_simple_html != blank %}  
            {{ product.metafields.se_product_z4.contenu_simple_html }}   
            {% endif %} 
            {% if product.metafields.se_product_z4.identifiant_page != blank %}  
            {% assign page_handle = product.metafields.se_product_z4.identifiant_page %}    
            {{ pages[page_handle].content }}
            {% endif %} 
          </div>
          {% endif %}
        </div>  

        {%- when 'extra_infos' -%}

        {{ block.settings.extra_infos_html1 }}

        <div class="delivery-date" 
             data-delivery-date-from="{{ block.settings.extra_infos_dd_fromdate }}" 
             data-delivery-date-to="{{ block.settings.extra_infos_dd_todate }}" 
             {% if block.settings.extra_infos_dd_saturday %}data-delivery-date-saturday="true" {% endif %} 
             style="display:none;">
          <svg xmlns="http://www.w3.org/2000/svg" height="24" width="24"><path d="M6 20Q4.75 20 3.875 19.125Q3 18.25 3 17H1V6Q1 5.175 1.588 4.588Q2.175 4 3 4H17V8H20L23 12V17H21Q21 18.25 20.125 19.125Q19.25 20 18 20Q16.75 20 15.875 19.125Q15 18.25 15 17H9Q9 18.25 8.125 19.125Q7.25 20 6 20ZM6 18Q6.425 18 6.713 17.712Q7 17.425 7 17Q7 16.575 6.713 16.288Q6.425 16 6 16Q5.575 16 5.287 16.288Q5 16.575 5 17Q5 17.425 5.287 17.712Q5.575 18 6 18ZM3 15H3.8Q4.225 14.55 4.775 14.275Q5.325 14 6 14Q6.675 14 7.225 14.275Q7.775 14.55 8.2 15H15V6H3Q3 6 3 6Q3 6 3 6ZM18 18Q18.425 18 18.712 17.712Q19 17.425 19 17Q19 16.575 18.712 16.288Q18.425 16 18 16Q17.575 16 17.288 16.288Q17 16.575 17 17Q17 17.425 17.288 17.712Q17.575 18 18 18ZM17 13H21.25L19 10H17ZM9 10.5Q9 10.5 9 10.5Q9 10.5 9 10.5Q9 10.5 9 10.5Q9 10.5 9 10.5Q9 10.5 9 10.5Q9 10.5 9 10.5Z"/></svg>
          <div>
            <p>{{ block.settings.extra_infos_dd_text1 }}
            <span id="ddFromDate">...</span> {{ block.settings.extra_infos_dd_text2 }} <span id="ddToDate">...</span>
            </p>
          </div>
        </div>
        {{ block.settings.extra_infos_html2 }}
        
        {%- when 'nav_products' -%}

        {{ 'nav-products.css' | asset_url | stylesheet_tag }} 
  
        <div class="nav-products block-{{ block.id }} {{ block.settings.class }}" id="{{ block.settings.id }}" {{ block.shopify_attributes }}>
          {% if collection.previous_product %}       
            <a href="{{ collection.previous_product }}" class="nav-products-link">
            <i class="fa fa-angle-left" aria-hidden="true"></i>
            {{ 'products.general.prev_product' | t }} |
            </a>       
          {% endif %} 
          {% if collection.previous_product and collection.next_product %}{% endif %}
          {% if collection.next_product %}        
          <a href="{{ collection.next_product }}" class="nav-products-link">             
            {{ 'products.general.next_product' | t }}
            <i class="fa fa-angle-right" aria-hidden="true"></i>
          </a>
          {% endif %}
        </div> 

        {%- when 'infos' -%} 
        <p class="product-meta block-{{ block.id }} {{ block.settings.class }}" id="{{ block.settings.id }} {{ block.shopify_attributes }}">

         {% if block.settings.show_vendor %}<span class="product-meta-info">{{- product.vendor -}}</span>{% endif %}
         {% if block.settings.show_type %} <span class="product-meta-info">{{- product.type -}}</span>{% endif %}
         {% if block.settings.show_collections %} 
         <span class="product-meta-info">
            {% for collection in product.collections %}
              <a href="{{ collection.url }}"> {{ collection.title }}</a>
            {% endfor %}
         </span> 
         {% endif %}
        </p>      
       
        {%- when 'form' -%}  
        <div class="block-{{ block.id }} {{ block.settings.class }}" id="{{ block.settings.id }}" {{ block.shopify_attributes }}>
          {% render "product-form-primary", block: block, product: product %} 
        </div>  
        
        {%- when 'social_proof' -%} 
        <div class="block-{{ block.id }} {{ block.settings.class }}" id="{{ block.settings.id }}" {{ block.shopify_attributes }}>
        {% render "social-proof", block: block %}  
        </div>

        {%- when 'form_secondary' -%}
        <div class="full-width block-{{ block.id }} {{ block.settings.class }} mt-2" id="{{ block.settings.id }}" {{ block.shopify_attributes }}> 
        
        {% render "product-form-secondary", block: block, product: product, block_id:block.id %}
        </div>

        {%- when 'custom_meta' -%}       
        <div class="shortcode shortcode-intro block-{{ block.id }} {{ block.settings.class }}" id="{{ block.settings.id }}" {{ block.shopify_attributes }}>
          {% if block.settings.meta_text_line %}{{ block.settings.meta_text_line }}{% endif %}   
          {% if block.settings.meta_text_multiline %}{{ block.settings.meta_text_multiline }}{% endif %}   
          {% if block.settings.meta_img %}  
          <img 
           loading="lazy"
           width= "{{ block.settings.meta_img.width }}"
           height= "{{ block.settings.meta_img.height }}"
           src="{{ block.settings.meta_img | image_url: width: block.settings.meta_img.width }}"
           alt="{{ block.settings.meta_img.alt }}"
           />  
           {% endif %}
        </div>
        
        {%- when 'content' -%} 
        <div class="rte block-{{ block.id }} {{ block.settings.class }}" id="{{ block.settings.id }}" {{ block.shopify_attributes }}>
          {{ block.settings.text }}
          {{ block.settings.html }}
        </div>

        {%- when 'liquid' -%}
        {{ block.settings.custom_liquid }}

        {%- when '@app' -%}
        {% render block %}
          
        {%- when 'description' -%}  
        <div class="grid-item small--one-whole rte full-width block-{{ block.id }} {{ block.settings.class }}" id="{{ block.settings.id }}" {{ block.shopify_attributes }}> 
          <div class="section-spaced">
          {{ product.description }} 
          </div>
        </div>

        {%- when 'countdown' -%}         
        {% if block.settings.product_cdtimer or product.description contains 'showcdtimer' -%}  
        <div class="block-{{ block.id }} {{ block.settings.class }}" id="{{ block.settings.id }}" {{ block.shopify_attributes }}>
        <link rel="stylesheet" href="{{ 'component-countdown.css' | asset_url }}" media="all" >       

        {% if block.settings.product_cdtimer_type == "0" %}          
        {% render "countdown", block: block %}          
        {% endif %}
        {% if block.settings.product_cdtimer_type == "1" %}          
        {% render "countdown-2", block: block %}          
        {% endif %}
        {% if block.settings.product_cdtimer_type == "2" %}          
        {% render "countdown-3", block: block %}       
        {% endif %}  
        </div>  
        {% endif %}

        {%- when 'accordion' -%} 
        {% render "accordion", block: block %}  

        {%- when 'accordions' -%} 
        {% render "accordions", block: block %}  
       
        {%- when 'sharing' -%} 
      
        {% render 'social-sharing', block: block %}

        {%- when 'tabs' -%} 
        {{ 'component-tabs.css' | asset_url | stylesheet_tag }}
        <div class="grid-item small--one-whole full-width" {{ block.shopify_attributes }}> 
        <div class="my-tab section-spaced block-{{ block.id }}  tabs-design-{{ block.settings.onglets_template }}">
              
          {% render 'product-template-tabs-nav', block: block, section: section, product: product %}    
          {% render 'product-template-tabs-content', section: section, product: product, block: block %}
        </div>
        </div>
        {%- when 'grid_close' -%} 
        </div>
       
        {%- endcase -%}  

        {% render 'product-block-custom-css', elem: block %}

      {%- endfor -%}

    </div>
      
  {% render "product-footer", block: block, product: product, section: section %}
    
  </div>
</div> 

{% render 'section-custom-css', elem: section %}

{% render 'thumbnails-script' %}

{% schema %}
