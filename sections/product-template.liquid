            },
            {
              "value": "small--two-quarters",
              "label": "50%"
            },
            {
              "value": " small--three-fifths",
              "label": "60%"
            },
            {
              "value": "small--two-thirds",
              "label": "67%"
            },
            {
              "value": "small--three-quarters",
              "label": "75%"
            },
            {
              "value": "small--one-whole",
              "label": "100%"
            }
          ],
          "default": "small--one-whole"
        },
        
        {
          "type": "header",
          "content": {
            "fr": "Personnalisation des couleurs",
