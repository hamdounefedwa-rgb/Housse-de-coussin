            "en": "Model 3"
          }
        }
       ]
    }    
    
  ],
  "presets": [
    {
      "name": {
        "fr": "Comparateur de produits",
        "es": "Comparateur de produits",
        "en": "Comparateur de produits"
      },     
      "category": {
        "fr": "Contenu",
