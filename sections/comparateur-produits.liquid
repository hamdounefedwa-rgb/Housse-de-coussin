      "default": "2",
      "options": [
        {
          "value": "0",
          "label": {
            "fr": "Modèle 1",
            "es": "Model 1",
            "en": "Model 1"
          }
        },
        {
          "value": "1",
          "label": {
            "fr": "Modèle 2",
            "es": "Model 2",
            "en": "Model 2"
          }
        },
        {
          "value": "2",
          "label": {
            "fr": "Modèle 3",
