{%- if predictive_search.performed -%}
  <div id="predictive-search-results">
    <ul id="predictive-search-results-list" class="predictive-search__results-list" role="listbox" aria-labelledby="predictive-search-products">
      {%- if predictive_search.resources.products.size > 0 -%}
      <li class="predictive-search__list-item title">
        <strong id="predictive-search-products" class="predictive-search__heading">{{ 'sitemap.products_title' | t }} ({{predictive_search.resources.products.size}})</strong>
      </li>
      {%- endif -%}
      {%- for product in predictive_search.resources.products -%}
        <li class="predictive-search__list-item" role="option">
          <a href="{{ product.url }}" class="predictive-search__item" tabindex="-1">
            <div class="predictive-search__item-image">
            {%- if product.featured_media != blank -%}
              <img class="predictive-search__image"
                src="{{ product.featured_media | img_url: '150x' }}"
                alt="{{ product.featured_media.alt }}"
                width="50"
                height="{{ 50 | divided_by: product.featured_media.preview_image.aspect_ratio }}"
              >
            {%- endif -%}
            </div>
            <div class="predictive-search__item-content">
              {%- if settings.predictive_search_show_vendor -%}
                <span class="visually-hidden">Vendor</span>
                <div class="predictive-search__item-vendor">{{ product.vendor }}</div>
              {%- endif -%}
              <span class="predictive-search__item-heading">{{ product.title }}</span>
              {%- if settings.predictive_search_show_price -%}
                {% comment %}Render price{% endcomment %}
              {%- endif -%}
            </div>
          </a>
        </li>
      {%- endfor -%}
      {%- if predictive_search.resources.collections.size > 0 -%}
      <li class="predictive-search__list-item title">
        <strong id="predictive-search-collections" class="predictive-search__heading">Collections ({{predictive_search.resources.collections.size}})</strong>
      </li>
      {%- endif -%}
      {%- for collection in predictive_search.resources.collections -%}
        <li class="predictive-search__list-item" role="option">
          <a href="{{ collection.url }}" class="predictive-search__item" tabindex="-1">
            <div class="predictive-search__item-image">
            {%- if collection.featured_image != blank -%}
              <img class="predictive-search__image"
                src="{{ collection.featured_image | img_url: '150x' }}"
                alt="{{ collection.featured_image.alt }}"
                width="50"
                height="{{ 50 | divided_by: collection.featured_image.preview_image.aspect_ratio }}"
              >
            {%- else -%}
              <svg xmlns="http://www.w3.org/2000/svg" height="40" width="40" fill="#606060"><path d="M6.125 33.333q-1.125 0-1.958-.833-.834-.833-.834-1.958V9.458q0-1.125.834-1.958.833-.833 1.958-.833h27.75q1.125 0 1.958.833.834.833.834 1.958v21.084q0 1.125-.834 1.958-.833.833-1.958.833Zm0-2.791h27.75V9.458H6.125v21.084Zm3.792-3.875h20.208l-6.167-8.292-5.333 7.042-3.792-5.25Zm-3.792 3.875V9.458v21.084Z"/></svg>
            {%- endif -%}
            </div>
            <div class="predictive-search__item-content">
              <span class="predictive-search__item-heading">{{ collection.title }}</span>
            </div>
          </a>
        </li>
      {%- endfor -%}
      {% if settings.search_field_post %}
      {%- if predictive_search.resources.articles.size > 0 -%}
      <li class="predictive-search__list-item title">
        <strong id="predictive-search-articles" class="predictive-search__heading">Articles ({{predictive_search.resources.articles.size}})</strong>
      </li>
      {%- endif -%}
      {%- for article in predictive_search.resources.articles -%}
        <li class="predictive-search__list-item" role="option">
          <a href="{{ article.url }}" class="predictive-search__item" tabindex="-1">
            <div class="predictive-search__item-image">
            {%- if article.featured_media != blank -%}
              <img class="predictive-search__image"
                src="{{ article.featured_media | img_url: '150x' }}"
                alt="{{ article.featured_media.alt }}"
                width="50"
                height="{{ 50 | divided_by: article.featured_media.preview_image.aspect_ratio }}"
              >
            {%- else -%}
              <svg xmlns="http://www.w3.org/2000/svg" height="40" width="40" fill="#606060"><path d="M6.125 33.333q-1.125 0-1.958-.833-.834-.833-.834-1.958V9.458q0-1.125.834-1.958.833-.833 1.958-.833h27.75q1.125 0 1.958.833.834.833.834 1.958v21.084q0 1.125-.834 1.958-.833.833-1.958.833Zm0-2.791h27.75V9.458H6.125v21.084Zm3.792-3.875h20.208l-6.167-8.292-5.333 7.042-3.792-5.25Zm-3.792 3.875V9.458v21.084Z"/></svg>
            {%- endif -%}
            </div>
            <div class="predictive-search__item-content">
              <span class="predictive-search__item-heading">{{ article.title }}</span>
            </div>
          </a>
        </li>
      {%- endfor -%}
      {% endif %}
      {% if settings.search_field_page %}
      {%- if predictive_search.resources.pages.size > 0 -%}
      <li class="predictive-search__list-item title">
        <strong id="predictive-search-pages" class="predictive-search__heading">Pages ({{predictive_search.resources.pages.size}})</strong>
      </li>
      {%- endif -%}
      {%- for page in predictive_search.resources.pages -%}
        <li class="predictive-search__list-item" role="option">
          <a href="{{ page.url }}" class="predictive-search__item" tabindex="-1">
            <div class="predictive-search__item-image">
            {%- if page.featured_media != blank -%}
              <img class="predictive-search__image"
                src="{{ page.featured_media | img_url: '150x' }}"
                alt="{{ page.featured_media.alt }}"
                width="50"
                height="{{ 50 | divided_by: page.featured_media.preview_image.aspect_ratio }}"
              >
            {%- else -%}
              <svg xmlns="http://www.w3.org/2000/svg" height="40" width="40" fill="#606060"><path d="M6.125 33.333q-1.125 0-1.958-.833-.834-.833-.834-1.958V9.458q0-1.125.834-1.958.833-.833 1.958-.833h27.75q1.125 0 1.958.833.834.833.834 1.958v21.084q0 1.125-.834 1.958-.833.833-1.958.833Zm0-2.791h27.75V9.458H6.125v21.084Zm3.792-3.875h20.208l-6.167-8.292-5.333 7.042-3.792-5.25Zm-3.792 3.875V9.458v21.084Z"/></svg>
            {%- endif -%}
            </div>
            <div class="predictive-search__item-content">
              <span class="predictive-search__item-heading">{{ page.title }}</span>
            </div>
          </a>
        </li>
      {%- endfor -%}
      {% endif %}
    </ul>
  </div>
{%- endif -%}