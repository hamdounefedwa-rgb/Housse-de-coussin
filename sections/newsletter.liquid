<link rel="stylesheet" href="{{ 'section-newsletter.css' | asset_url }}" media="print" onload="this.media='all'">
<noscript>{{ 'section-newsletter.css' | asset_url | stylesheet_tag }}</noscript>

<div class="{% if section.settings.section_spaced %}section-spaced{% endif %} {% if section.settings.full_page %} wrapper-full-page {% else %} wrapper{% endif %} color-scheme {{ section.settings.color_scheme }} 
  newsletter-section text-center section-id-{{ section.id }} wow slideInUp {{ section.settings.class }}" 
  id="{{ section.settings.id }}"  
  data-wow-duration="{{ settings.wow_effects_duration }}s" 
  data-wow-delay="{{ settings.wow_effects_delay }}s"
  data-section-id="{{ section.id }}" 
  data-section-type="home-newsletter">
 <div class="newsletter-container">
    <div class="section-header section-header--layout-{{ section.settings.title_layout }}">
      {% if section.settings.title != blank %}
      <{{ section.settings.title_hn }} class="h1 {{ section.settings.title_hn }} section-header--left section-title">{{ section.settings.title | escape }}</{{ section.settings.title_hn }}>
      {% endif %}
    </div> 
    {% if section.settings.text != blank %}
    <{{ section.settings.text_hn }}>{{ section.settings.text | escape }}</{{ section.settings.text_hn }}>
    {% endif %}
    {% render 'newsletter-form' %}
 </div> 
</div>        

{% render 'section-custom-css', elem: section %}
{% render 'section-newsletter-custom-css', elem: section %}
      
