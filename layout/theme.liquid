
<!doctype html>
<html class="no-touch no-js" lang="{{ request.locale.iso_code }}">
<head>
  {%- comment -%}
  Vous avez un code à mettre dans la balise Head ? Google, Facebook, codes d'applications...
  Mettez-les plutôt dans Paramètres du theme - Codes HTML et Scripts afin de les conserver à chaque mise à jour 
  {%- endcomment -%}
  <meta charset="utf-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge,chrome=1">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, shrink-to-fit=no" />
  <meta name="theme-color" content="{{ settings.mobile_theme_color }}">
  {%- if settings.favicon -%}
  <link rel="shortcut icon" href="{{ settings.favicon | img_url: '32x32' }}" type="image/png" />
  <link rel="apple-touch-icon" href="{{ settings.favicon | img_url: '128x128' }}">
  {%- endif -%}
  <title>
    {{ page_title }}{% if current_tags %}{% assign current_tags_joined = current_tags | join: ', ' %} &ndash; {{ 'general.meta.tags' | t: tags: current_tags_joined }}{% endif %}{% if current_page != 1 %} &ndash; {{ 'general.meta.page' | t: page: current_page }}{% endif %}{% unless page_title contains shop.name %}{% if settings.seo_title_website %}{% else %} &ndash; {{ shop.name }}{% endif %}{% endunless %}
  </title>  
  {%- if collection.handle == "all" -%}
  <meta name="description" content="{{ settings.seo_meta_collections_all }}">
  {% elsif template == "list-collections" %}
  <meta name="description" content="{{ settings.seo_meta_collections }}">
  {% else %}       
  <meta name="description" content="{{ page_description | escape | remove: '[intro]' | remove: '[/intro]' }}">    
  {%- endif -%} 
 
  {%- render 'social-meta-tags' -%}
  {% if template == 'collection' %}
  <link rel="canonical" href="{{ shop.url }}{{ collection.url }}" />
  {% else %}
  <link rel="canonical" href="{{ canonical_url }}" />
  {% endif %}

  {%- if template == "page.noindex" or template == "page.noindex-nocontent" -%}
  <meta name="robots" content="noindex, nofollow"> 
  {%- endif -%}      

  {{ content_for_header }} 

  <!-- CSS - JS ================================================== -->     
  <link rel="preconnect" href="https://cdn.shopify.com" as="style" crossorigin>
  <link rel="preconnect" href="https://fonts.shopifycdn.com" crossorigin>  
  <link rel="preconnect" href="https://v.shopify.com" /> 
  <link rel="preconnect" href="https://cdn.shopifycloud.com" /> 
  <link rel="preconnect" href="https://monorail-edge.shopifysvc.com">  
  <link rel="preconnect" href="https://cdnjs.cloudflare.com">   

  {% render 'css-variables' %} 
 
  <link rel="preload" href={{ 'font-awesome.min.css' | asset_url }} as="style" onload="this.rel='stylesheet'">  

  {{ 'theme.css' | asset_url | stylesheet_tag }}
  
  <script src="{{ 'vendor.js' | asset_url }}" defer></script> 
  <script src="{{ 'jquery-3.6.0.min.js' | asset_url }}"></script> 
  <script src="{{ 'theme.js' | asset_url }}" defer></script>   
   
  
  {% if settings.wow_effects == true %}
  <script src="{{ 'wow.js' | asset_url }}" defer></script>  
  {% endif %}

  {% if template.directory == 'customers' %} 
  {{ 'shopify_common.js' | shopify_asset_url | script_tag }}
  {{ 'customer_area.js' | shopify_asset_url | script_tag }}
  <link rel="preload" href={{ 'customer.css' | asset_url }} as="style" onload="this.rel='stylesheet'">   
  {% endif %}   
  
  <!-- Code script ================================================== -->
  {{ settings.code_head_ga }}     
  {{ settings.code_head }}

  <style>
    .slideshow .slide:not(:first-child), .slick-slider .slick-slide:not(:first-child) { display: none; opacity: 0; }
    .slideshow.slick-initialized .slide, .slick-slider.slick-initialized .slick-slide, .slick-slider.slick-initialized .slideshow-show-true  { display: block !important; opacity: 1; } 
    .slick-slider  { opacity: 0; }
    .slick-slider.slick-initialized { opacity: 1 !important; }
  </style>

  <script type="text/javascript">
    (function(c,l,a,r,i,t,y){
        c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
        t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
        y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
    })(window, document, "clarity", "script", "mw1vo9c6oj");
</script>

  
</head>

<body {% if settings.body_bg_img %} style="background-image:url({{ settings.body_bg_img | img_url: "original" }});" {% endif %} id="{{ page_title | handle }}" 
  class="{% if customer %}customer-logged-in {% endif %}template-{{ template | replace: '.', ' ' | truncatewords: 1, '' | handle }}">
  
  <div id="pixel-to-watch"></div>
  {% section 'header' %} 
  
  <div class="mega-menu-container">
    {% if settings.mega_menu_1 %}{% section 'mega-menu-1' %}{% endif %}
    {% if settings.mega_menu_2 %}{% section 'mega-menu-2' %}{% endif %}
    {% if settings.mega_menu_3 %}{% section 'mega-menu-3' %}{% endif %}
    {% if settings.mega_menu_4 %}{% section 'mega-menu-4' %}{% endif %}
    {% if settings.mega_menu_5 %}{% section 'mega-menu-5' %}{% endif %}
    {% if settings.mega_menu_6 %}{% section 'mega-menu-6' %}{% endif %}
  </div>     
  
  <main class="main-content" role="main">  
    <div class=" {% if template != "index" %}no-template-index {% else %} is-template-index {% endif %} no-padding">   
      {{ content_for_layout }}
    </div>      
  </main>
  
  {% section 'advanced-content' %}        
  {% section 'footer' %}  
  {% if settings.ajax_cart_method != 'page' %}
  {% render 'mini-cart' method: 'mini-cart' %}
  {% else %}
  {% render 'mini-cart' method: 'cart' %}
  {% endif %}

  <script defer>    
    const moneyFormat = '{{ shop.money_format }}';
    const theme = {
      strings:{
        product:{
          unavailable: {{ 'products.product.unavailable' | t | json }},
          will_be_in_stock_after:{{ 'products.product.will_be_in_stock_after' | t: date: '[date]' | json }},
          unitPrice: {{ 'products.product.unit_price_label' | t | json }},
          unitPriceSeparator: {{ 'accessibility.unit_price_separator' | t | json }},
          only_left:{{ 'products.product.only_left' | t: count: '1' | json }}
        },
        navigation:{
          more_link: {{ 'layout.navigation.more' | t | json }}
        }
      }
    }
  </script>

  {% render 'swatch-script' %}    

  {% if settings.newsletter_popup_enabled %}
  {% render 'newsletter-popup' %} 
  {% endif %}

  {% if settings.euro_cookies %}
  {% render 'cookie-banner' %}  
  {% endif %} 

  {% if settings.code_footer %}
  <div class="codes-apps">{{ settings.code_footer }}</div>
  {% endif %}         
  
  {% if settings.back_to_top_enable %}  
  <div id="toTop" class="toTop"><i class="fa fa-arrow-up"></i></div>
  {% endif %} 
  
  {% if settings.perf_css_surcharge %}
  {{ 'surcharge.css' | asset_url | stylesheet_tag }}   
  {% endif %}

  {% if settings.perf_js_surcharge %}
  <script src="{{ 'surcharge.js' | asset_url }}" rel="preload" defer></script>  
  {% endif %}

  {% if settings.perf_speed %}
  {% render 'test-speed-perf' %} 
  {% endif %}   

  {% render 'size-chart' product: product %}   
  
  {%- comment -%}
  Vous avez un code à mettre dans la balise Body ? Codes d'applications ou autres
  Mettez-les plutôt dans Paramètres du theme - Codes HTML et Scripts afin de les conserver à chaque mise à jour 
  {%- endcomment -%}
  
  <div class="theme-traduction" data-trad-read-more="{{ 'general.text.read_more' | t }}" data-trad-read-less="{{ 'general.text.read_less' | t }}"></div>

</body>
</html>